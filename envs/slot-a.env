# Slot A — SLOT_INDEX=0 → all services get base ports (8080, 8081, 4200, ...)
# Run ./stack ports slot-a to see the full port table

STACK_NAME=xcel-a
SLOT_INDEX=0
WORKSPACE=/Users/tharun/repo/xcelerate

# Source repos — point any *_SRC_DIR at a feature clone to swap that service
CB_SRC_DIR=xcelerate-contractor-backend
CF_SRC_DIR=xcelerate-contractor-frontend
CORP_BACKEND_SRC_DIR=xcelerate-corporate-backend
CORP_FRONTEND_SRC_DIR=xcelerate-corporate-frontend
