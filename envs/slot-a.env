XIPP_BACKEND_SRC_DIR=xcelerate-invoice-payment-processor
XIPP_FRONTEND_SRC_DIR=xcelerate-ipp-frontend-v1
INTEG_SVC_SRC_DIR=xcelerate-integration-services
COMPANYCAM_SRC_DIR=xcelerate-companycam-integration
ENCIRCLE_SRC_DIR=xcelerate-encircle-integration
GOOGLE_SRC_DIR=xcelerate-google-integration
OUTLOOK_SRC_DIR=xcelerate-outlook-integration
VERISK_SRC_DIR=xcelerate-verisk-integration
ERP_SRC_DIR=xcelerate-erp-integration
NETSUITE_SRC_DIR=xcelerate-netsuite-integration
